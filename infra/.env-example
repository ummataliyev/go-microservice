# =============================================================================
# Server
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_ENVIRONMENT=development
SERVER_DEBUG=true
SERVER_APP_NAME=go-microservice
SERVER_APP_VERSION=0.1.0
SERVER_API_PREFIX=/api/v1
SERVER_DB_PROVIDER=postgres          # postgres | mysql | mongo
SERVER_TRUSTED_HOSTS=localhost,127.0.0.1

# =============================================================================
# JWT / Authentication
# =============================================================================
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h

# =============================================================================
# Auth brute-force protection
# =============================================================================
AUTH_MAX_ATTEMPTS=5
AUTH_WINDOW_SECONDS=300
AUTH_LOCKOUT_SECONDS=900

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DSN=postgres://devuser:devpassword@postgres:5432/app_dev?sslmode=disable
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=300

# =============================================================================
# MySQL
# =============================================================================
MYSQL_DSN=root:devpassword@tcp(mysql:3306)/app_dev?parseTime=true

# =============================================================================
# MongoDB
# =============================================================================
MONGO_URI=mongodb://mongo:27017
MONGO_DATABASE=app_dev

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=5

# =============================================================================
# Rate limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LIMIT_GET=60
RATE_LIMIT_LIMIT_POST=20
RATE_LIMIT_LIMIT_PUT=20
RATE_LIMIT_LIMIT_DELETE=10
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Pagination
# =============================================================================
PAGINATION_MAX_PER_PAGE=100

# =============================================================================
# Logging
# =============================================================================
LOGGING_LEVEL=debug
LOGGING_SLOW_REQUEST_THRESHOLD_MS=500
